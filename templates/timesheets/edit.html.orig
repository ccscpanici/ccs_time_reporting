{% extends "base.html" %}
{% block content %}
<h1 class="h3 mb-3">Edit week of {{ timesheet.week_start }}</h1>
<form method="post" class="mb-5" id="weekly-timesheet-edit-form">
  {% csrf_token %}
  <datalist id="job-options">
    {% for job in job_options %}
      <option value="{{ job.job_number }}" label="{{ job.label }}" data-status="{{ job.status }}" data-warning="{% if job.warning %}1{% else %}0{% endif %}">{{ job.label }}</option>
    {% endfor %}
  </datalist>
  <div class="card shadow-sm border-0 rounded-4 mb-3">
    <div class="card-body">
      <label class="form-label" for="entries_per_day">Time entry rows per date</label>
      <input class="form-control" style="max-width: 10rem" type="number" min="5" max="25" name="entries_per_day" id="entries_per_day" value="{{ timesheet.entries_per_day }}">
      <div class="form-text">The Excel template supports 5 rows per date. More rows are allowed online and export as PDF.</div>
    </div>
  </div>

  <ul class="nav nav-tabs mb-3" id="timesheetEditTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="time-tab" data-bs-toggle="tab" data-bs-target="#time-pane" type="button" role="tab" aria-controls="time-pane" aria-selected="true">Time</button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="expenses-tab" data-bs-toggle="tab" data-bs-target="#expenses-pane" type="button" role="tab" aria-controls="expenses-pane" aria-selected="false">Expenses</button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="parts-tab" data-bs-toggle="tab" data-bs-target="#parts-pane" type="button" role="tab" aria-controls="parts-pane" aria-selected="false">Parts</button>
    </li>
  </ul>

  <div class="tab-content">
    <div class="tab-pane fade show active" id="time-pane" role="tabpanel" aria-labelledby="time-tab" tabindex="0">
      {% for day in grid %}
      <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-center rounded-top-4">
          <strong>{{ day.work_date|date:"l m/d/Y" }}</strong>
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" name="overnight_{{ day.work_date|date:'Y-m-d' }}" id="overnight_{{ day.work_date|date:'Y-m-d' }}" {% if day.overnight_stay %}checked{% endif %}>
            <label class="form-check-label" for="overnight_{{ day.work_date|date:'Y-m-d' }}">Hotel overnight stay</label>
          </div>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-bordered align-middle mb-0 timesheet-entry-table">
            <thead>
              <tr><th style="width: 3rem">#</th><th style="min-width: 10rem">Project / Job</th><th style="min-width: 6rem">Work Code</th><th class="hours-col">Reg</th><th class="hours-col">OT</th><th class="hours-col">DT</th><th class="description-col">Description</th></tr>
            </thead>
            <tbody>
              {% for row in day.rows %}
              {% with entry=row.entry key=day.work_date|date:'Y-m-d' %}
              <tr>
                <td>{{ row.row_order }}</td>
                <td><input class="form-control form-control-sm job-input" list="job-options" name="entry_{{ key }}_{{ row.row_order }}_job_number" value="{% if entry %}{{ entry.job_display }}{% endif %}" placeholder="Blank for internal"><div class="form-text text-warning small job-warning d-none"></div></td>
                <td>
                  <select class="form-select form-select-sm work-code-select-compact" name="entry_{{ key }}_{{ row.row_order }}_work_code">
                    <option value="">---</option>
                    {% for code in work_codes %}
                      <option
                        value="{{ code.pk }}"
                        data-code="{{ code.code }}"
                        data-label="{{ code }}"
                        {% if entry and entry.work_code_id == code.pk %}selected{% endif %}
                      >
                        {{ code }}
                      </option>
                    {% endfor %}
                  </select>
                </td>
                <td><input class="form-control form-control-sm hours-input" type="number" step="0.25" name="entry_{{ key }}_{{ row.row_order }}_regular_hours" value="{% if entry %}{{ entry.regular_hours }}{% endif %}"></td>
                <td><input class="form-control form-control-sm hours-input" type="number" step="0.25" name="entry_{{ key }}_{{ row.row_order }}_overtime_hours" value="{% if entry %}{{ entry.overtime_hours }}{% endif %}"></td>
                <td><input class="form-control form-control-sm hours-input" type="number" step="0.25" name="entry_{{ key }}_{{ row.row_order }}_doubletime_hours" value="{% if entry %}{{ entry.doubletime_hours }}{% endif %}"></td>
                <td><input class="form-control form-control-sm description-input" name="entry_{{ key }}_{{ row.row_order }}_description" value="{% if entry %}{{ entry.description }}{% endif %}"></td>
              </tr>
              {% endwith %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="tab-pane fade" id="expenses-pane" role="tabpanel" aria-labelledby="expenses-tab" tabindex="0">
      <div class="alert alert-info rounded-4">Expenses are tied one-to-one to the matching time row for the same date and row number. Mileage dollars are calculated from miles × the timesheet mileage rate (${{ timesheet.mileage_rate }}).</div>
      {% for day in grid %}
      <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-body-tertiary rounded-top-4">
          <strong>{{ day.work_date|date:"l m/d/Y" }}</strong>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-bordered align-middle mb-0 timesheet-expense-table">
            <thead>
              <tr><th style="width: 3rem">#</th><th style="min-width: 10rem">Job #</th><th>Miles</th><th>Mileage</th><th>Per Diem Food</th><th>Air Fare</th><th>Hotel</th><th>Tolls/Parking</th><th>Rental Car/Fuel</th><th>Business Meals</th><th>Other</th><th class="description-col">Explanation</th></tr>
            </thead>
            <tbody>
              {% for row in day.rows %}
              {% with entry=row.entry key=day.work_date|date:'Y-m-d' %}
              <tr>
                <td>{{ row.row_order }}</td>
                <td class="text-body-secondary small">{% if entry %}{{ entry.job_display }}{% endif %}</td>
                <td><input class="form-control form-control-sm expense-number-input mileage-miles" data-rate="{{ timesheet.mileage_rate }}" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_expense_miles" value="{% if entry.expense %}{{ entry.expense.miles }}{% endif %}"></td>
                <td><input class="form-control form-control-sm expense-number-input mileage-amount" type="text" value="{% if entry.expense %}${{ entry.expense.mileage.amount|floatformat:2 }}{% else %}$0.00{% endif %}" readonly tabindex="-1"></td>
                <td><input class="form-control form-control-sm expense-number-input" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_expense_per_diem_food" value="{% if entry.expense %}{{ entry.expense.per_diem_food.amount }}{% endif %}"></td>
                <td><input class="form-control form-control-sm expense-number-input" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_expense_air_fare" value="{% if entry.expense %}{{ entry.expense.air_fare.amount }}{% endif %}"></td>
                <td><input class="form-control form-control-sm expense-number-input" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_expense_hotel" value="{% if entry.expense %}{{ entry.expense.hotel.amount }}{% endif %}"></td>
                <td><input class="form-control form-control-sm expense-number-input" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_expense_tolls_parking" value="{% if entry.expense %}{{ entry.expense.tolls_parking.amount }}{% endif %}"></td>
                <td><input class="form-control form-control-sm expense-number-input" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_expense_rental_car_fuel" value="{% if entry.expense %}{{ entry.expense.rental_car_fuel.amount }}{% endif %}"></td>
                <td><input class="form-control form-control-sm expense-number-input" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_expense_business_meals" value="{% if entry.expense %}{{ entry.expense.business_meals.amount }}{% endif %}"></td>
                <td><input class="form-control form-control-sm expense-number-input" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_expense_other_expense" value="{% if entry.expense %}{{ entry.expense.other_expense.amount }}{% endif %}"></td>
                <td><input class="form-control form-control-sm description-input" name="entry_{{ key }}_{{ row.row_order }}_expense_explanation_of_expenses" value="{% if entry.expense %}{{ entry.expense.explanation_of_expenses }}{% endif %}"></td>
              </tr>
              {% endwith %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="tab-pane fade" id="parts-pane" role="tabpanel" aria-labelledby="parts-tab" tabindex="0">
      <div class="alert alert-info rounded-4">Parts are tied one-to-one to the matching time row for the same date and row number.</div>
      {% for day in grid %}
      <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-body-tertiary rounded-top-4">
          <strong>{{ day.work_date|date:"l m/d/Y" }}</strong>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-bordered align-middle mb-0 timesheet-parts-table">
            <thead>
              <tr>
                <th style="width: 3rem">#</th>
                <th style="min-width: 10rem">EE Stock/Job #</th>
                <th>Quantity</th>
                <th style="min-width: 18rem">Part Description/Part Number</th>
                <th class="description-col">Additional Notes For Customer</th>
                <th>Re-Order Part</th>
              </tr>
            </thead>
            <tbody>
              {% for row in day.rows %}
              {% with entry=row.entry key=day.work_date|date:'Y-m-d' %}
              <tr>
                <td>{{ row.row_order }}</td>
                <td><input class="form-control form-control-sm part-job-input" name="entry_{{ key }}_{{ row.row_order }}_part_ee_stock_job_number" value="{% if entry.part_entry %}{{ entry.part_entry.ee_stock_job_number }}{% elif entry %}{{ entry.job_display }}{% endif %}" placeholder="EE Stock/Job #"></td>
                <td><input class="form-control form-control-sm expense-number-input" type="number" step="0.01" name="entry_{{ key }}_{{ row.row_order }}_part_quantity" value="{% if entry.part_entry %}{{ entry.part_entry.quantity }}{% endif %}"></td>
                <td><input class="form-control form-control-sm description-input" name="entry_{{ key }}_{{ row.row_order }}_part_description_part_number" value="{% if entry.part_entry %}{{ entry.part_entry.part_description_part_number }}{% endif %}"></td>
                <td><input class="form-control form-control-sm description-input" name="entry_{{ key }}_{{ row.row_order }}_part_additional_notes_for_customer" value="{% if entry.part_entry %}{{ entry.part_entry.additional_notes_for_customer }}{% endif %}"></td>
                <td class="text-center"><input class="form-check-input" type="checkbox" name="entry_{{ key }}_{{ row.row_order }}_part_reorder_part" {% if entry.part_entry and entry.part_entry.reorder_part %}checked{% endif %}></td>
              </tr>
              {% endwith %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <button class="btn btn-primary" type="submit">Save draft</button>
  <a class="btn btn-outline-secondary" href="{{ timesheet.get_absolute_url }}">Cancel</a>
</form>
<script>
(function weeklyEditKeyboardBehavior() {
  const form = document.querySelector('form[method="post"]');
  if (!form) return;

  let isDirty = false;
  let isSubmitting = false;

  function editableControls() {
    return Array.from(form.querySelectorAll('input, select, textarea, button'))
      .filter(function(control) {
        if (control.disabled) return false;
        if (control.type === 'hidden') return false;
        if (control.type === 'submit') return false;
        if (control.type === 'button') return false;
        if (control.type === 'checkbox') return false;
        if (control.readOnly) return false;
        return control.offsetParent !== null;
      });
  }

  function moveToNextControl(current) {
    const controls = editableControls();
    const index = controls.indexOf(current);
    if (index === -1) return;

    const next = controls[index + 1];
    if (next) {
      next.focus();
      if (typeof next.select === 'function') {
        next.select();
      }
    } else {
      current.blur();
    }
  }

  form.addEventListener('keydown', function(event) {
    if (event.key !== 'Enter') return;

    const target = event.target;
    if (!target || target.tagName === 'TEXTAREA') return;
    if (!target.matches('input, select')) return;

    event.preventDefault();
    target.dispatchEvent(new Event('change', { bubbles: true }));
    moveToNextControl(target);
  });

  form.addEventListener('input', function() {
    isDirty = true;
  });

  form.addEventListener('change', function() {
    isDirty = true;
  });

  form.addEventListener('submit', function() {
    isSubmitting = true;
    isDirty = false;
  });

  window.addEventListener('beforeunload', function(event) {
    if (!isDirty || isSubmitting) return;
    event.preventDefault();
    event.returnValue = '';
  });

  document.addEventListener('click', function(event) {
    const link = event.target.closest('a[href]');
    if (!link || !form.contains(link)) return;
    if (!isDirty || isSubmitting) return;

    const okToLeave = window.confirm('You have unsaved changes. Leave this page without saving?');
    if (!okToLeave) {
      event.preventDefault();
    }
  });
})();
</script>
<script>
document.addEventListener("input", function (event) {
  if (!event.target.classList.contains("mileage-miles")) return;
  const input = event.target;
  const row = input.closest("tr");
  const output = row ? row.querySelector(".mileage-amount") : null;
  if (!output) return;
  const miles = parseFloat(input.value || "0") || 0;
  const rate = parseFloat(input.dataset.rate || "0") || 0;
  output.value = "$" + (miles * rate).toFixed(2);
});
</script>
<script>
(function compactWorkCodeSelects() {
  function showCodesOnly(select) {
    Array.from(select.options).forEach(function(option) {
      if (option.dataset.code) {
        option.textContent = option.dataset.code;
      }
    });
  }

  function showDescriptions(select) {
    Array.from(select.options).forEach(function(option) {
      if (option.dataset.label) {
        option.textContent = option.dataset.label;
      }
    });
  }

  document.querySelectorAll(".work-code-select-compact").forEach(function(select) {
    showCodesOnly(select);

    select.addEventListener("focus", function() {
      showDescriptions(select);
    });

    select.addEventListener("mousedown", function() {
      showDescriptions(select);
    });

    select.addEventListener("change", function() {
      window.setTimeout(function() {
        showCodesOnly(select);
      }, 100);
    });

    select.addEventListener("blur", function() {
      showCodesOnly(select);
    });
  });
})();
</script>

<script>
(function projectJobWarnings() {
  const optionList = Array.from(document.querySelectorAll('#job-options option'));

  function findJob(value) {
    const normalized = (value || '').trim().toLowerCase();
    if (!normalized) return null;
    return optionList.find(function(option) {
      return (option.value || '').trim().toLowerCase() === normalized;
    }) || null;
  }

  function updateWarning(input) {
    const cell = input.closest('td');
    const warning = cell ? cell.querySelector('.job-warning') : null;
    if (!warning) return;

    const option = findJob(input.value);
    if (option && option.dataset.warning === '1') {
      const status = option.dataset.status || 'Unknown Status';
      warning.textContent = 'Warning: this job is currently marked as "' + status + '". Please verify time should be charged to this project.';
      warning.classList.remove('d-none');
    } else {
      warning.textContent = '';
      warning.classList.add('d-none');
    }
  }

  document.querySelectorAll('.job-input').forEach(updateWarning);
  document.addEventListener('input', function(event) {
    if (!event.target.classList.contains('job-input')) return;
    updateWarning(event.target);
  });
})();
</script>

<script>
(function weeklyEditSaveBehavior() {
  const form = document.getElementById('weekly-timesheet-edit-form');
  if (!form) return;

  let isSubmitting = false;
  let isDirty = false;
  const scrollKey = 'weekly-timesheet-edit-scroll-{{ timesheet.pk }}';

  function saveScrollPosition() {
    try {
      sessionStorage.setItem(scrollKey, String(window.scrollY || 0));
    } catch (error) {
      // Ignore storage errors. Saving should never depend on this.
    }
  }

  function restoreScrollPosition() {
    try {
      const savedY = sessionStorage.getItem(scrollKey);
      if (savedY !== null) {
        sessionStorage.removeItem(scrollKey);
        window.scrollTo(0, parseInt(savedY, 10) || 0);
      }
    } catch (error) {
      // Ignore storage errors.
    }
  }

  restoreScrollPosition();

  form.addEventListener('input', function () {
    isDirty = true;
  });

  form.addEventListener('change', function () {
    isDirty = true;
  });

  form.addEventListener('submit', function () {
    isSubmitting = true;
    isDirty = false;
    saveScrollPosition();
  });

  form.addEventListener('keydown', function (event) {
    if (event.key !== 'Enter') return;

    const target = event.target;
    if (!target) return;

    const tagName = (target.tagName || '').toLowerCase();
    const type = (target.getAttribute('type') || '').toLowerCase();

    if (tagName === 'textarea') return;
    if (type === 'button' || type === 'submit' || type === 'reset') return;

    event.preventDefault();
    isSubmitting = true;
    isDirty = false;
    saveScrollPosition();

    if (form.requestSubmit) {
      form.requestSubmit();
    } else {
      form.submit();
    }
  });

  window.addEventListener('beforeunload', function (event) {
    if (!isDirty || isSubmitting) return;
    event.preventDefault();
    event.returnValue = '';
  });
})();
</script>
{% endblock %}
