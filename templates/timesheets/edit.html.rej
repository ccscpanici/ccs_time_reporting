 </script>
+
+<script>
+(function projectJobWarnings() {
+  const optionList = Array.from(document.querySelectorAll('#job-options option'));
+
+  function findJob(value) {
+    const normalized = (value || '').trim().toLowerCase();
+    if (!normalized) return null;
+    return optionList.find(function(option) {
+      return (option.value || '').trim().toLowerCase() === normalized;
+    }) || null;
+  }
+
+  function updateWarning(input) {
+    const cell = input.closest('td');
+    const warning = cell ? cell.querySelector('.job-warning') : null;
+    if (!warning) return;
+
+    const option = findJob(input.value);
+    if (option && option.dataset.warning === '1') {
+      const status = option.dataset.status || 'Unknown Status';
+      warning.textContent = 'Warning: this job is currently marked as "' + status + '". Please verify time should be charged to this project.';
+      warning.classList.remove('d-none');
+    } else {
+      warning.textContent = '';
+      warning.classList.add('d-none');
+    }
+  }
+
+  document.querySelectorAll('.job-input').forEach(updateWarning);
+  document.addEventListener('input', function(event) {
+    if (!event.target.classList.contains('job-input')) return;
+    updateWarning(event.target);
+  });
+})();
+</script>
 {% endblock %}
